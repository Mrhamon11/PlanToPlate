# ==========================================
# 1. Embedded SQLite Database & Local Data
# ==========================================
# Never commit the local production database or its temporary runtime states
plantoplate.db
*.db
*.db-shm
*.db-wal
plantoplate_data/
app/data/

# ==========================================
# 2. Build & Target Outputs (Maven / Gradle)
# ==========================================
target/
build/
out/
.gradle/
bin/
*.class
*.jar
*.war
*.ear

# ==========================================
# 3. IntelliJ IDEA Configuration
# ==========================================
.idea/
*.iml
*.iws
*.ipr
*.clover
/out/

# ==========================================
# 4. Terminal & OS System Artifacts
# ==========================================
# Linux / Unix system file caches
.directory
.Trash-*
*~
# macOS system artifacts (in case you pull or view on a mac)
.DS_Store
AppleDouble
.LSOverride
# Windows artifacts
Thumbs.db
ehthumbs.db
Desktop.ini

# ==========================================
# 5. Environment & Sensitive Configuration
# ==========================================
# Local application overrides (use application-local.yml for machine-specific values)
src/main/resources/application-local.yml
src/main/resources/application-local.properties
.env
.env.*
*.log
logs/

# ==========================================
# 6. Local AI Agent & Editor Backups
# ==========================================
# Exclude local terminal agent cache logs if generated by automated runners
.pi/
.agent/
.history/
*.swp
*.bak